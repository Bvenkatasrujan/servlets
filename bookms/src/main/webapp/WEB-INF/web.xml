<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xmlns="https://jakarta.ee/xml/ns/jakartaee"
xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
version="6.0">

<display-name>bookms</display-name>

<welcome-file-list>
<welcome-file>login.jsp</welcome-file>
</welcome-file-list>

<servlet>
<servlet-name>CreateUser</servlet-name>
<servlet-class>users.CreateUser</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>CreateUser</servlet-name>
<url-pattern>/cr_user</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>DeleteUser</servlet-name>
<servlet-class>users.DeleteUser</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>DeleteUser</servlet-name>
<url-pattern>/del_user</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>Authentication</servlet-name>
<servlet-class>users.Authentication</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>Authentication</servlet-name>
<url-pattern>/auth</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>Signout</servlet-name>
<servlet-class>users.Signout</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>Signout</servlet-name>
<url-pattern>/signout</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>ChangePassword</servlet-name>
<servlet-class>users.ChangePassword</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>ChangePassword</servlet-name>
<url-pattern>/chpwd</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>CreateBook</servlet-name>
<servlet-class>books.CreateBook</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>CreateBook</servlet-name>
<url-pattern>/crbook</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>DeleteBook</servlet-name>
<servlet-class>books.DeleteBook</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>DeleteBook</servlet-name>
<url-pattern>/delbook</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>ChangeBook</servlet-name>
<servlet-class>books.ChangeBook</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>ChangeBook</servlet-name>
<url-pattern>/chbook</url-pattern>
</servlet-mapping>
</web-app>